# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenRouter (LLM routing)
OPENROUTER_API_KEY=your-openrouter-key

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret
# Public base URL for setWebhook (HTTPS, e.g. https://xxxx.ngrok-free.app). Optional if the proxy sends x-forwarded-host.
TELEGRAM_WEBHOOK_BASE_URL=

# Github OAuth App (https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URL=http://localhost:3000/api/integrations/github/callback

# Notion public OAuth integration (https://www.notion.so/profile/integrations/public).
# Must be a Public integration (not Internal). Set the redirect URI in the
# Notion dashboard to match NOTION_OAUTH_REDIRECT_URL exactly.
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_OAUTH_REDIRECT_URL=http://localhost:3000/api/integrations/notion/callback

# OAuth encryption key (32 bytes hex). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OAUTH_ENCRYPTION_KEY=generate-a-32-byte-hex-key
